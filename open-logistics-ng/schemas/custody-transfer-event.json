{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-logistics-ng.github.io/schema/schemas/custody-transfer-event.json",
  "title": "CustodyTransferEvent",
  "description": "A Proof of Handover (PoH) event capturing the transfer of physical custody between two actors in a logistics chain.",
  "type": "object",
  "required": [
    "@context", "@type", "eventTime", "epcList",
    "bizStep", "giverActorType", "receiverName",
    "receiverActorType", "proofHash", "proofAlgorithm"
  ],
  "properties": {
    "@context": {
      "oneOf": [
        { "type": "string", "format": "uri" },
        { "type": "array",  "items": { "type": "string", "format": "uri" } }
      ]
    },
    "@type": {
      "type": "string",
      "const": "CustodyTransferEvent"
    },
    "eventTime": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the handover occurred."
    },
    "epcList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^urn:ol:waybill:[a-zA-Z0-9_-]+$"
      },
      "description": "List of waybill URNs whose custody is being transferred."
    },
    "bizStep": {
      "type": "string",
      "enum": [
        "urn:epcglobal:cbv:bizstep:receiving",
        "urn:epcglobal:cbv:bizstep:in_transit",
        "urn:epcglobal:cbv:bizstep:staging_outbound",
        "urn:epcglobal:cbv:bizstep:delivering"
      ]
    },
    "readPoint": {
      "type": "object",
      "properties": {
        "latitude":  { "type": "number" },
        "longitude": { "type": "number" }
      },
      "description": "GPS coordinates where the handover took place."
    },
    "giverActorType": {
      "type": "string",
      "enum": ["ACTOR_SENDER", "ACTOR_COURIER", "ACTOR_HUB", "ACTOR_RECEIVER"]
    },
    "receiverName": {
      "type": "string",
      "minLength": 1,
      "description": "Full name of the person receiving custody."
    },
    "receiverActorType": {
      "type": "string",
      "enum": ["ACTOR_SENDER", "ACTOR_COURIER", "ACTOR_HUB", "ACTOR_RECEIVER"]
    },
    "proofHash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA-256 hex digest used as the immutable Proof of Handover."
    },
    "proofAlgorithm": {
      "type": "string",
      "const": "SHA-256",
      "description": "Hash algorithm used to compute proofHash."
    }
  },
  "additionalProperties": true
}
