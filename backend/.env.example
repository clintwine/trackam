# Server
PORT=4429
FRONTEND_URL=http://127.0.0.1:3429
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60

# PostgreSQL
DATABASE_URL=postgres://postgres@127.0.0.1:6429/trackam

# Auth
JWT_SECRET=6fb01ad5a3c754fa004fad448f299de23bf9d27d9b360d1388c34fd5bcf35e8f
JWT_EXPIRATION_SECONDS=3600

# Session cookies
SESSION_COOKIE_NAME=trackam_session
SESSION_COOKIE_MAX_AGE_DAYS=7
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=

# Bootstrap admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=Pk5HU4MhPlj1qpIl1_h0R7Oc
BOOTSTRAP_ADMIN_DISPLAY_NAME=Scaffold Admin

# Storage
STORAGE_DIRECTORY=storage
STORAGE_URL_PREFIX=http://127.0.0.1:4429/storage


# OLI Switch (private — set these in Railway environment)
OLI_SWITCH_URL=http://localhost:5000
OLI_API_KEY=
# Your operator UUID from the OLI Switch registry (returned after operator registration)
OLI_OPERATOR_ID=
# Public base URL of this trackam instance — used in JSON-LD currentCustodian responses
# Falls back to the request host if not set, but should be explicit in production
OLI_TRACKING_ENDPOINT=
